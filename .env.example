APP_NAME=XAU/USD Trading Bot
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost"]
DATABASE_URL=sqlite+aiosqlite:///./backend/data/trading_bot.db
LOG_LEVEL=INFO
VITE_API_BASE_URL=/api/v1
FRONTEND_PORT=5173
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
MT5_SYMBOL=XAUUSD
MARKET_TICK_CACHE_TTL_SECONDS=0.25
MARKET_CANDLE_CACHE_TTL_SECONDS=1.0
MARKET_CACHE_MAX_ENTRIES=128
MARKET_MAX_CANDLES=1000
MARKET_WS_INTERVAL_SECONDS=1.0
ANALYSIS_EMA_FAST_PERIOD=20
ANALYSIS_EMA_SLOW_PERIOD=50
ANALYSIS_RSI_PERIOD=14
ANALYSIS_ATR_PERIOD=14
ANALYSIS_RSI_OVERBOUGHT=70
ANALYSIS_RSI_OVERSOLD=30
ANALYSIS_MAX_SPREAD_POINTS=300
ANALYSIS_CANDLE_COUNT=120
ANALYSIS_CANDLE_BODY_ATR_MIN=0.2
ANALYSIS_CANDLE_CLOSE_LOCATION_MIN=0.65
ANALYSIS_STRUCTURE_LOOKBACK=20
ANALYSIS_SR_LOOKBACK=50
ANALYSIS_SWING_WINDOW=2
ANALYSIS_MAX_LEVELS=5
ANALYSIS_STRATEGY_NAME=EMA_RSI_ATR_MTF_V1
RISK_PER_TRADE_PERCENT=1.0
RISK_MAX_DAILY_LOSS_PERCENT=3.0
RISK_MAX_DAILY_DRAWDOWN_PERCENT=5.0
RISK_MAX_CONSECUTIVE_LOSSES=3
RISK_MAX_TRADES_PER_DAY=5
RISK_MAX_OPEN_POSITIONS=1
RISK_MINIMUM_RISK_REWARD=1.5
RISK_TARGET_RISK_REWARD=2.0
RISK_MAXIMUM_SPREAD_POINTS=300
RISK_COOLDOWN_MINUTES_AFTER_LOSS=30
RISK_USE_EQUITY_FOR_RISK=true
RISK_BREAK_EVEN_ENABLED=false
RISK_TRAILING_STOP_ENABLED=false
RISK_STOP_LOSS_METHOD=ATR
RISK_ATR_MULTIPLIER=1.5
RISK_SESSION_ENABLED=true
RISK_SESSION_START_HOUR_UTC=0
RISK_SESSION_END_HOUR_UTC=24
RISK_SESSION_WEEKDAYS=[0,1,2,3,4]
PAPER_INITIAL_BALANCE=10000
PAPER_SLIPPAGE_POINTS=0
PAPER_COMMISSION_PER_LOT=0
PAPER_SWAP_LONG_PER_LOT=0
PAPER_SWAP_SHORT_PER_LOT=0
PAPER_UPDATE_INTERVAL_SECONDS=1
PAPER_AUTO_TRADE_ENABLED=false
PAPER_MAXIMUM_OPEN_POSITIONS=1
PAPER_ALLOW_MANUAL_TRADE_PLAN=true
PAPER_CLOSE_POSITIONS_ON_STOP=false
PAPER_EMERGENCY_CLOSE_POSITIONS=true
PAPER_BREAK_EVEN_ENABLED=false
PAPER_BREAK_EVEN_TRIGGER_R=1
PAPER_TRAILING_STOP_ENABLED=false
PAPER_TRAILING_STOP_METHOD=POINTS
PAPER_TRAILING_DISTANCE_POINTS=0
PAPER_TRAILING_ATR_MULTIPLIER=1
